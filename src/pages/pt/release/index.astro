---
import Layout from '../../../layouts/Layout.astro';
import EventTabs from '../../../components/EventTabs.astro';
import DataTable from '../../../components/DataTable.astro';
import PublicationCard from '../../../components/PublicationCard.astro';
import SuggestionCard from '../../../components/SuggestionCard.astro';
import { t } from '../../../i18n/utils';
import genomeData from '../../../data/release-genome.json';
import populationData from '../../../data/release-population.json';
import otherData from '../../../data/release-other.json';
import suggestionsData from '../../../data/release-suggestions.json';
import publicationsData from '../../../data/release-publications.json';

const locale = 'pt';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = ['genome', 'population_genome', 'other_genetic', 'suggestions', 'publications'] as const;
const tabCategories = categories.map(key => ({
  key,
  label: t(locale, `nav_release.${key}`),
}));

const genomeColumns = [
  { key: 'species', label: t(locale, 'release.table_species') },
  { key: 'assembly', label: t(locale, 'release.table_assembly') },
  { key: 'version', label: t(locale, 'release.table_version') },
  { key: 'size', label: t(locale, 'release.table_size') },
  { key: 'database', label: t(locale, 'release.table_database') },
  { key: 'accession', label: t(locale, 'release.table_accession') },
  { key: 'link', label: t(locale, 'release.table_link') },
];

const populationColumns = [
  { key: 'species', label: t(locale, 'release.table_species') },
  { key: 'population', label: t(locale, 'release.table_population') },
  { key: 'seq_type', label: t(locale, 'release.table_seq_type') },
  { key: 'data_size', label: t(locale, 'release.table_data_size') },
  { key: 'database', label: t(locale, 'release.table_database') },
  { key: 'accession', label: t(locale, 'release.table_accession') },
  { key: 'link', label: t(locale, 'release.table_link') },
];

const otherColumns = [
  { key: 'species', label: t(locale, 'release.table_species') },
  { key: 'resource_type', label: t(locale, 'release.table_resource_type') },
  { key: 'marker', label: t(locale, 'release.table_marker') },
  { key: 'database', label: t(locale, 'release.table_database') },
  { key: 'accession', label: t(locale, 'release.table_accession') },
  { key: 'link', label: t(locale, 'release.table_link') },
];
---

<Layout title={t(locale, 'release.page_title')} locale={locale}>
  <section class="page-hero" style={`background-image: url(${base}/images/backgrounds/bg3.png)`}>
    <div class="page-hero__overlay"></div>
    <h1 class="page-hero__title pixel-font">{t(locale, 'release.page_title')}</h1>
  </section>

  <section class="section">
    <div class="container">
      <EventTabs categories={tabCategories} activeCategory="genome" />

      <div class="tab-panel tab-panel--active" data-panel="genome">
        <p class="tab-desc">{t(locale, 'release.genome_desc')}</p>
        {genomeData.rows.length > 0 ? (
          <DataTable
            columns={genomeColumns}
            rows={genomeData.rows}
            searchPlaceholder={t(locale, 'common.search')}
            csvFilename="bivalveplus-genome.csv"
            downloadLabel={t(locale, 'common.download_csv')}
            noResultsLabel={t(locale, 'common.no_results')}
          />
        ) : (
          <p class="coming-soon pixel-font">{t(locale, 'release.coming_soon')}</p>
        )}
      </div>

      <div class="tab-panel" data-panel="population_genome">
        <p class="tab-desc">{t(locale, 'release.population_desc')}</p>
        {populationData.rows.length > 0 ? (
          <DataTable
            columns={populationColumns}
            rows={populationData.rows}
            searchPlaceholder={t(locale, 'common.search')}
            csvFilename="bivalveplus-population-genome.csv"
            downloadLabel={t(locale, 'common.download_csv')}
            noResultsLabel={t(locale, 'common.no_results')}
          />
        ) : (
          <p class="coming-soon pixel-font">{t(locale, 'release.coming_soon')}</p>
        )}
      </div>

      <div class="tab-panel" data-panel="other_genetic">
        <p class="tab-desc">{t(locale, 'release.other_desc')}</p>
        {otherData.rows.length > 0 ? (
          <DataTable
            columns={otherColumns}
            rows={otherData.rows}
            searchPlaceholder={t(locale, 'common.search')}
            csvFilename="bivalveplus-other-genetic.csv"
            downloadLabel={t(locale, 'common.download_csv')}
            noResultsLabel={t(locale, 'common.no_results')}
          />
        ) : (
          <p class="coming-soon pixel-font">{t(locale, 'release.coming_soon')}</p>
        )}
      </div>

      <div class="tab-panel" data-panel="suggestions">
        <p class="tab-desc">{t(locale, 'release.suggestions_desc')}</p>
        {suggestionsData.items.length > 0 ? (
          suggestionsData.items.map((item: { title: string; pdfUrl?: string }) => (
            <SuggestionCard
              title={item.title}
              pdfUrl={item.pdfUrl}
              downloadLabel={t(locale, 'release.download_pdf')}
              commentsPlaceholder={t(locale, 'release.comments_placeholder')}
            />
          ))
        ) : (
          <p class="coming-soon pixel-font">{t(locale, 'release.coming_soon')}</p>
        )}
      </div>

      <div class="tab-panel" data-panel="publications">
        <p class="tab-desc">{t(locale, 'release.publications_desc')}</p>
        {publicationsData.items.length > 0 ? (
          publicationsData.items.map((pub: { authors: string; year: string; title: string; journal: string; volume?: string; pages?: string; doi?: string }) => (
            <PublicationCard
              authors={pub.authors}
              year={pub.year}
              title={pub.title}
              journal={pub.journal}
              volume={pub.volume}
              pages={pub.pages}
              doi={pub.doi}
            />
          ))
        ) : (
          <p class="coming-soon pixel-font">{t(locale, 'release.coming_soon')}</p>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
  }
  .page-hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.4); }
  .page-hero__title { position: relative; z-index: 2; color: var(--color-white); font-size: 1.3rem; text-shadow: 3px 3px 0px rgba(0,0,0,0.5); }

  .tab-panel { display: none; }
  .tab-panel--active { display: block; }

  .tab-desc {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .coming-soon {
    text-align: center;
    font-size: 0.6rem;
    color: var(--color-neutral);
    padding: 3rem 0;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.event-tab');
    const panels = document.querySelectorAll('.tab-panel');

    function switchTab(category: string) {
      tabs.forEach(tab => {
        const isActive = tab.getAttribute('data-category') === category;
        tab.classList.toggle('event-tab--active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach(panel => {
        panel.classList.toggle('tab-panel--active', panel.getAttribute('data-panel') === category);
      });
      history.replaceState(null, '', `#${category}`);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-category');
        if (category) switchTab(category);
      });
    });

    const hash = window.location.hash.replace('#', '');
    const validTabs = ['genome', 'population_genome', 'other_genetic', 'suggestions', 'publications'];
    if (hash && validTabs.includes(hash)) {
      switchTab(hash);
    }

    window.addEventListener('hashchange', () => {
      const newHash = window.location.hash.replace('#', '');
      if (newHash && validTabs.includes(newHash)) {
        switchTab(newHash);
      }
    });
  });
</script>
