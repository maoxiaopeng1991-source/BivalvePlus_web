---
import { type Locale, locales } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function switchLocalePath(targetLocale: string): string {
  // Remove base and current locale prefix, then prepend new locale
  let path = currentPath;
  if (base) {
    path = path.replace(base, '');
  }
  // Remove current locale prefix
  for (const loc of locales) {
    if (path.startsWith(`/${loc}/`) || path === `/${loc}`) {
      path = path.slice(loc.length + 1) || '/';
      break;
    }
  }
  return `${base}/${targetLocale}${path}`;
}

const labels: Record<string, string> = {
  en: 'EN',
  pt: 'PT',
};
---

<div class="lang-switcher">
  {locales.map((loc) => (
    <a
      href={switchLocalePath(loc)}
      class:list={['lang-switcher__link', 'pixel-font', { active: loc === locale }]}
    >
      {labels[loc]}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: flex;
    border: 2px solid var(--color-white);
  }

  .lang-switcher__link {
    font-size: 0.5rem;
    padding: 0.3rem 0.5rem;
    color: var(--color-white);
    text-decoration: none;
    transition: all 0.2s;
  }

  .lang-switcher__link:first-child {
    border-right: 2px solid var(--color-white);
  }

  .lang-switcher__link.active {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .lang-switcher__link:hover:not(.active) {
    background: var(--color-accent-light);
  }
</style>
