---
import { type Locale, t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="footer">
  <div class="pixel-divider"></div>
  <div class="footer__inner container">
    <!-- Left: Logo + Slogan + Funding -->
    <div class="footer__col footer__branding">
      <img
        src={`${base}/images/logos/bivalveplus-logo.png`}
        alt="BivalvePlus"
        class="footer__logo pixel-art"
      />
      <p class="footer__slogan">{t(locale, 'site.slogan')}</p>
      <div class="footer__funding">
        <p class="pixel-font footer__label">{t(locale, 'footer.funded_by')}</p>
        <div class="footer__fund-logos">
          <img src={`${base}/images/logos/logo-fct.png`} alt="FCT" class="fund-logo" />
          <img src={`${base}/images/logos/logo-portugal-2030.png`} alt="Portugal 2030" class="fund-logo" />
          <img src={`${base}/images/logos/logo-algarve-2030.png`} alt="Algarve 2030" class="fund-logo" />
        </div>
      </div>
    </div>

    <!-- Middle: Contact -->
    <div class="footer__col footer__contact">
      <h3 class="pixel-font footer__label">{t(locale, 'footer.contact')}</h3>
      <p class="footer__address">{t(locale, 'footer.address')}</p>
      <p class="footer__email">
        <a href="mailto:mxpeng@ualg.pt">mxpeng@ualg.pt</a> (Dr. Maoxiao Peng)
      </p>
      <p class="footer__email">
        <a href="mailto:dpower@ualg.pt">dpower@ualg.pt</a> (Prof. Deborah Mary Power)
      </p>
    </div>

    <!-- Right: CCMAR Logo + Link -->
    <div class="footer__col footer__ccmar">
      <a href="https://ccmar.ualg.pt/en/ccmar" target="_blank" rel="noopener noreferrer">
        <img
          src={`${base}/images/logos/ccmar-ualg-logo.png`}
          alt="CCMAR - University of Algarve"
          class="footer__ccmar-logo"
        />
      </a>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {new Date().getFullYear()} BivalvePlus. Ref: 2023.17014.ICDT</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-neutral-dark);
    color: var(--color-white);
    padding-top: 0;
  }

  .footer .pixel-divider {
    background: repeating-linear-gradient(
      90deg,
      var(--color-primary) 0px,
      var(--color-primary) 4px,
      transparent 4px,
      transparent 8px
    );
    margin: 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr 0.6fr;
    gap: var(--space-xl);
    padding: var(--space-xl) var(--space-lg);
  }

  .footer__logo {
    height: 220px;
    width: auto;
    margin-bottom: var(--space-sm);
  }

  .footer__slogan {
    font-size: 0.85rem;
    color: var(--color-accent-light);
    margin-bottom: var(--space-md);
  }

  .footer__label {
    font-size: 0.6rem;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
  }

  .footer__fund-logos {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  .fund-logo {
    height: 44px;
    width: auto;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .fund-logo:hover {
    opacity: 1;
  }

  .footer__address {
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: var(--space-sm);
    color: var(--color-accent-light);
  }

  .footer__email {
    font-size: 0.85rem;
    margin-bottom: var(--space-xs);
  }

  .footer__email a {
    color: var(--color-primary-light);
  }

  .footer__ccmar {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__ccmar-logo {
    max-width: 220px;
    height: auto;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .footer__ccmar-logo:hover {
    opacity: 1;
  }

  .footer__bottom {
    text-align: center;
    padding: var(--space-md) 0;
    border-top: 2px solid var(--color-neutral);
    font-size: 0.8rem;
    color: var(--color-neutral-light);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer__ccmar {
      justify-content: flex-start;
    }
  }
</style>
