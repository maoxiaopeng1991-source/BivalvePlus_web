---
interface Props {
  title: string;
  date: string;
  description: string;
  image?: string;
  body?: string;
}

const { title, date, description, image, body } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Format date for display
const displayDate = new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="event-card pixel-box">
  {image && (
    <div class="event-card__image">
      <img src={`${base}${image}`} alt={title} loading="lazy" />
    </div>
  )}
  <div class="event-card__content">
    <time class="event-card__date pixel-font" datetime={date}>{displayDate}</time>
    <h3 class="event-card__title">{title}</h3>
    <p class="event-card__desc">{description}</p>
    {body && (
      <div class="event-card__body" set:html={body} />
    )}
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .event-card:hover {
    transform: translateY(-3px);
  }

  .event-card__image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .event-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-card__content {
    padding: 1.2rem;
  }

  .event-card__date {
    display: inline-block;
    font-size: 0.55rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .event-card__title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .event-card__desc {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .event-card__body {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.6;
    border-top: 1px dashed var(--color-accent);
    padding-top: 0.5rem;
    margin-top: 0.5rem;
  }

  .event-card__body :global(em) {
    font-style: italic;
  }

  /* placeholder when no image */
  .event-card__image:empty {
    display: none;
  }
</style>
