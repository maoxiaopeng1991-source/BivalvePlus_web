---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Locale, defaultLocale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const {
  title = 'BivalvePlus',
  description = 'Genetic resources for economically important bivalves in Portugal',
  locale = defaultLocale,
} = Astro.props;

const fullTitle = title === 'BivalvePlus' ? title : `${title} | BivalvePlus`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}images/favicon.png`} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - var(--header-height) - 300px);
  }
</style>
